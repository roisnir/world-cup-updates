# Copy to .env (which is gitignored) and fill in real values.
# The script auto-loads ./.env, so cron needs no extra env wiring.

# From @BotFather after you create the bot:
TELEGRAM_BOT_TOKEN=123456789:AA-your-bot-token-here

# Target channel. Use @publicchannelname for a public channel,
# or the numeric -100xxxxxxxxxx id for a private channel.
# (The bot must be an ADMIN of the channel to post.)
TELEGRAM_CHAT_ID=@your_channel
