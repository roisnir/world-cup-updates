# Copy to .env (which is gitignored) and fill in real values.
# The script auto-loads ./.env, so cron needs no extra env wiring.

# From @BotFather after you create the bot:
TELEGRAM_BOT_TOKEN=123456789:AA-your-bot-token-here

# Target channel. Use @publicchannelname for a public channel,
# or the numeric -100xxxxxxxxxx id for a private channel.
# (The bot must be an ADMIN of the channel to post.)
TELEGRAM_CHAT_ID=@your_channel

# --- WhatsApp (Baileys) — optional, runs in parallel to Telegram ---------
# One-time setup: cd whatsapp && npm install, then pair this machine with
#   python wc_exact_score.py --whatsapp-login   (scan the QR with your phone).
# Then find your group's JID with:
#   python wc_exact_score.py --whatsapp-groups
# and paste it below (it looks like 123456789-123456@g.us, newer ones differ).
WHATSAPP_GROUP_JID=123456789-123456@g.us

# Optional overrides:
# WHATSAPP_NODE=/usr/bin/node          # path to Node if not on PATH (e.g. cron)
# WHATSAPP_AUTH_DIR=/abs/path/to/auth  # where linked-device creds are stored
